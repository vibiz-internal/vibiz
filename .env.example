# Auth — only set DATABASE_URL to enable sign-in
# Local dev: file:./dev.db (SQLite, works out of the box)
# Production: set automatically by vibiz on deploy (Turso)
# Leave empty for landing-page-only mode (no auth)
DATABASE_URL=file:./dev.db
BETTER_AUTH_SECRET=change-me-to-a-random-string
BETTER_AUTH_URL=http://localhost:3100

# Turso (production only — set automatically by vibiz)
# TURSO_AUTH_TOKEN=

# Stripe
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3100
